  "safety_rules": [
    {
      "if": "Allergy casein = yes",
      "then": "НЕ назначать GC Tooth Mousse / MI Paste"
    },
    {
      "if": "Implant = yes",
      "then": "избегать aggressive whitening"
    },
    {
      "if": "Erosion severe = yes",
      "then": "избегать high RDA"
    },
    {
      "if": "CHX >14 days",
      "then": "stop protocol"
    },
    {
      "if": "Xerostomia = yes",
      "then": "only alcohol free"
    },
    {
      "if": "Braces = yes",
      "then": "mandatory interdental care"
    },
    {
      "if": "Halitosis = yes",
      "then": "mandatory tongue cleaning"
    },
    {
      "if": "Sensitivity = severe",
      "then": "ultra soft + low RDA"
    }
  ],
  "auto_assignment": [
    {
      "if": "API >70%",
      "then": "ёршики + ирригатор"
    },
    {
      "if": "White spots + braces",
      "then": "MI Paste Plus"
    },
    {
      "if": "Implant + bleeding",
      "then": "peri-implant protocol"
    },
    {
      "if": "Xerostomia + caries",
      "then": "fluoride + saliva support"
    },
    {
      "if": "High plaque",
      "then": "AirFlow + CHX"
    },
    {
      "if": "Halitosis + tongue coating",
      "then": "tongue-care protocol"
    }
