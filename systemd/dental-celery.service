[Unit]
Description=Odonta Index AI Celery Worker
After=network.target redis.service dental-backend.service

[Service]
Type=simple
User=deploy
WorkingDirectory=/opt/dental-ai
ExecStart=/opt/dental-ai/.venv/bin/celery -A app.celery_app worker --loglevel=info --concurrency=2
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
